---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ThemeToggle from "../../components/ThemeToggle.astro";
import Sidebar from "../../components/Sidebar.astro";
import Toc from "../../components/Toc.astro";
import { getRepos, getWiki, getPageContent, buildNavigation, extractHeadings, slugify, escapeHtml } from "../../lib/content";
import { Marked } from "marked";
import markedKatex from "marked-katex-extension";

export function getStaticPaths() {
  const repos = getRepos();
  const paths: any[] = [];

  for (const repo of repos) {
    const wiki = getWiki(repo.slug);
    if (!wiki) continue;

    // Index route → redirect to first page
    if (wiki.pages.length > 0) {
      paths.push({
        params: { repo: repo.slug, slug: undefined },
        props: { redirect: `/${repo.slug}/${wiki.pages[0].slug}` },
      });
    }

    for (const page of wiki.pages) {
      paths.push({
        params: { repo: repo.slug, slug: page.slug },
        props: {
          repoMeta: repo,
          wiki,
          currentPage: page,
        },
      });
    }
  }

  return paths;
}

const { redirect, repoMeta, wiki, currentPage } = Astro.props;

if (redirect) {
  return Astro.redirect(redirect);
}

const sections = buildNavigation(wiki.pages);
const rawMarkdown = getPageContent(repoMeta.slug, currentPage.file);

// Build TOC: page title as first entry, then H2/H3 from markdown
const titleId = slugify(currentPage.title);
const headings = [
  { depth: 1, text: currentPage.title, id: titleId },
  ...extractHeadings(rawMarkdown),
];

// Add IDs to headings and KaTeX support
const marked = new Marked();
marked.use(markedKatex({ throwOnError: false }));
marked.use({
  renderer: {
    heading({ text, depth }: { text: string; depth: number }) {
      return `<h${depth} id="${slugify(text)}">${text}</h${depth}>`;
    },
    code({ text, lang }: { text: string; lang?: string }) {
      if (lang === "mermaid") {
        return `<div class="mermaid">${text}</div>`;
      }
      return `<pre><code class="language-${escapeHtml(lang || "")}">${escapeHtml(text)}</code></pre>`;
    },
  },
});

const htmlContent = await marked.parse(rawMarkdown);
const pageTitle = `${currentPage.title} - ${repoMeta.name}`;

const githubIcon = `<svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>`;
---

<BaseLayout title={pageTitle}>
  <header class="site-header">
    <div class="header-inner">
      <div class="header-left">
        <a href="/" class="header-logo">zread</a>
        <div class="header-breadcrumb">
          <span class="sep">/</span>
          <a href={`/${repoMeta.slug}/${wiki.pages[0]?.slug || ""}`}>{repoMeta.name}</a>
          <span class="sep">/</span>
          <button class="breadcrumb-toc-trigger" id="breadcrumb-toc-trigger">
            <span>{currentPage.title}</span>
            <svg class="breadcrumb-toc-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="breadcrumb-toc-dropdown" id="breadcrumb-toc-dropdown">
            <div class="toc-title">On this page</div>
            <ul class="toc-list">
              {headings.map((h) => (
                <li>
                  <a
                    href={h.depth === 1 ? "#" : `#${h.id}`}
                    class:list={["toc-link", `depth-${h.depth}`]}
                  >
                    {h.text}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
      <div class="header-right">
        {repoMeta.github && (
          <a href={repoMeta.github} target="_blank" rel="noopener" class="gh-link">
            <Fragment set:html={githubIcon} />
            <span>Source</span>
          </a>
        )}
        <div class="mobile-toc-wrapper">
          <button class="mobile-toc-btn" id="mobile-toc-btn" aria-label="Table of contents">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
              <line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="14" y2="18"/>
            </svg>
          </button>
          <div class="mobile-toc-dropdown" id="mobile-toc-dropdown">
            <div class="toc-title">On this page</div>
            <ul class="toc-list">
              {headings.map((h) => (
                <li>
                  <a
                    href={h.depth === 1 ? "#" : `#${h.id}`}
                    class:list={["toc-link", `depth-${h.depth}`]}
                  >
                    {h.text}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
        <ThemeToggle />
      </div>
    </div>
  </header>

  <div class="wiki-layout">
    <Sidebar sections={sections} repoSlug={repoMeta.slug} currentSlug={currentPage.slug} />

    <main class="wiki-main">
      <h1 id={titleId}>{currentPage.title}</h1>
      <div class="markdown-body" set:html={htmlContent} />
    </main>

    <Toc headings={headings} />
  </div>

  <!-- Mobile sidebar toggle -->
  <button class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle navigation">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="3" y1="12" x2="21" y2="12" />
      <line x1="3" y1="6" x2="21" y2="6" />
      <line x1="3" y1="18" x2="21" y2="18" />
    </svg>
  </button>
  <div class="sidebar-overlay" id="sidebar-overlay"></div>

  <script is:inline>
    (function () {
      const toggle = document.getElementById("sidebar-toggle");
      const sidebar = document.getElementById("sidebar");
      const overlay = document.getElementById("sidebar-overlay");
      if (!toggle || !sidebar || !overlay) return;

      function close() {
        sidebar.classList.remove("open");
        overlay.classList.remove("open");
      }

      toggle.addEventListener("click", () => {
        sidebar.classList.toggle("open");
        overlay.classList.toggle("open");
      });

      overlay.addEventListener("click", close);

      // Close on navigation
      sidebar.querySelectorAll("a").forEach((a) => a.addEventListener("click", close));
    })();
  </script>

  <script is:inline>
    (function () {
      var trigger = document.getElementById("breadcrumb-toc-trigger");
      var dropdown = document.getElementById("breadcrumb-toc-dropdown");
      if (!trigger || !dropdown) return;

      trigger.addEventListener("click", function (e) {
        e.stopPropagation();
        var open = trigger.classList.toggle("open");
        dropdown.classList.toggle("open", open);
      });

      document.addEventListener("click", function () {
        trigger.classList.remove("open");
        dropdown.classList.remove("open");
      });

      dropdown.querySelectorAll("a").forEach(function (a) {
        a.addEventListener("click", function () {
          trigger.classList.remove("open");
          dropdown.classList.remove("open");
        });
      });
    })();
  </script>

  <script is:inline>
    (function () {
      var btn = document.getElementById("mobile-toc-btn");
      var dd = document.getElementById("mobile-toc-dropdown");
      if (!btn || !dd) return;

      btn.addEventListener("click", function (e) {
        e.stopPropagation();
        dd.classList.toggle("open");
      });

      document.addEventListener("click", function () {
        dd.classList.remove("open");
      });

      dd.querySelectorAll("a").forEach(function (a) {
        a.addEventListener("click", function () {
          dd.classList.remove("open");
        });
      });
    })();
  </script>

  <script is:inline>
    if (document.querySelector(".mermaid")) {
      var s = document.createElement("script");
      s.src = "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js";
      s.onload = function () {
        var theme = document.documentElement.getAttribute("data-theme") === "dark" ? "dark" : "default";
        mermaid.initialize({ startOnLoad: true, theme: theme });
      };
      document.head.appendChild(s);
    }
  </script>
</BaseLayout>
