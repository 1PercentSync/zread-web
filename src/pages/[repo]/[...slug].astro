---
import type { GetStaticPathsResult } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ThemeToggle from "../../components/ThemeToggle.astro";
import Sidebar from "../../components/Sidebar.astro";
import Toc from "../../components/Toc.astro";
import GithubIcon from "../../components/GithubIcon.astro";
import { getRepos, getWiki, getPageContent, buildNavigation, extractHeadings, slugify, escapeHtml } from "../../lib/content";
import { Marked } from "marked";
import markedKatex from "marked-katex-extension";

export function getStaticPaths(): GetStaticPathsResult {
  const repos = getRepos();
  const paths: GetStaticPathsResult = [];

  for (const repo of repos) {
    const wiki = getWiki(repo.slug);
    if (!wiki) continue;

    // Index route → redirect to first page
    if (wiki.pages.length > 0) {
      paths.push({
        params: { repo: repo.slug, slug: undefined },
        props: { redirect: `/${repo.slug}/${wiki.pages[0].slug}` },
      });
    }

    for (const page of wiki.pages) {
      paths.push({
        params: { repo: repo.slug, slug: page.slug },
        props: {
          repoMeta: repo,
          wiki,
          currentPage: page,
        },
      });
    }
  }

  return paths;
}

const { redirect, repoMeta, wiki, currentPage } = Astro.props;

if (redirect) {
  return Astro.redirect(redirect);
}

const sections = buildNavigation(wiki.pages);
const rawMarkdown = getPageContent(repoMeta.slug, currentPage.file);

// Build TOC: page title as first entry, then H2/H3 from markdown
const titleId = slugify(currentPage.title);
const headings = [
  { depth: 1, text: currentPage.title, id: titleId },
  ...extractHeadings(rawMarkdown),
];

// Add IDs to headings and KaTeX support
const marked = new Marked();
marked.use(markedKatex({ throwOnError: false }));
marked.use({
  renderer: {
    heading({ text, depth }: { text: string; depth: number }) {
      return `<h${depth} id="${slugify(text)}">${text}</h${depth}>`;
    },
    code({ text, lang }: { text: string; lang?: string }) {
      if (lang === "mermaid") {
        return `<div class="mermaid">${text}</div>`;
      }
      return `<pre><code class="language-${escapeHtml(lang || "")}">${escapeHtml(text)}</code></pre>`;
    },
  },
});

const htmlContent = await marked.parse(rawMarkdown);
const pageTitle = `${currentPage.title} - ${repoMeta.name}`;
---

<BaseLayout title={pageTitle}>
  <header class="site-header">
    <div class="header-inner">
      <div class="header-left">
        <a href="/" class="header-logo">zread</a>
        <div class="header-breadcrumb">
          <span class="sep">/</span>
          <a href={`/${repoMeta.slug}/${wiki.pages[0]?.slug || ""}`}>{repoMeta.name}</a>
          <span class="sep">/</span>
          <button class="breadcrumb-toc-trigger" id="breadcrumb-toc-trigger">
            <span>{currentPage.title}</span>
            <svg class="breadcrumb-toc-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="breadcrumb-toc-dropdown" id="breadcrumb-toc-dropdown">
            <div class="toc-title">On this page</div>
            <ul class="toc-list">
              {headings.map((h) => (
                <li>
                  <a
                    href={h.depth === 1 ? "#" : `#${h.id}`}
                    class:list={["toc-link", `depth-${h.depth}`]}
                  >
                    {h.text}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
      <div class="header-right">
        {repoMeta.github && (
          <a href={repoMeta.github} target="_blank" rel="noopener" class="gh-link">
            <GithubIcon />
            <span>Source</span>
          </a>
        )}
        <div class="mobile-toc-wrapper">
          <button class="mobile-toc-btn" id="mobile-toc-btn" aria-label="Table of contents">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
              <line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="14" y2="18"/>
            </svg>
          </button>
          <div class="mobile-toc-dropdown" id="mobile-toc-dropdown">
            <div class="toc-title">On this page</div>
            <ul class="toc-list">
              {headings.map((h) => (
                <li>
                  <a
                    href={h.depth === 1 ? "#" : `#${h.id}`}
                    class:list={["toc-link", `depth-${h.depth}`]}
                  >
                    {h.text}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
        <ThemeToggle />
      </div>
    </div>
  </header>

  <div class="wiki-layout">
    <Sidebar sections={sections} repoSlug={repoMeta.slug} currentSlug={currentPage.slug} />

    <main class="wiki-main">
      <h1 id={titleId}>{currentPage.title}</h1>
      <div class="markdown-body" set:html={htmlContent} />
    </main>

    <Toc headings={headings} />
  </div>

  <!-- Mobile sidebar toggle -->
  <button class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle navigation">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="3" y1="12" x2="21" y2="12" />
      <line x1="3" y1="6" x2="21" y2="6" />
      <line x1="3" y1="18" x2="21" y2="18" />
    </svg>
  </button>
  <div class="sidebar-overlay" id="sidebar-overlay"></div>

  <script is:inline>
    (function () {
      const toggle = document.getElementById("sidebar-toggle");
      const sidebar = document.getElementById("sidebar");
      const overlay = document.getElementById("sidebar-overlay");
      if (!toggle || !sidebar || !overlay) return;

      function close() {
        sidebar.classList.remove("open");
        overlay.classList.remove("open");
      }

      toggle.addEventListener("click", () => {
        sidebar.classList.toggle("open");
        overlay.classList.toggle("open");
      });

      overlay.addEventListener("click", close);

      // Close on navigation
      sidebar.querySelectorAll("a").forEach((a) => a.addEventListener("click", close));
    })();
  </script>

  <script is:inline>
    (function () {
      function setupDropdown(triggerId, dropdownId, syncTrigger) {
        var trigger = document.getElementById(triggerId);
        var dropdown = document.getElementById(dropdownId);
        if (!trigger || !dropdown) return;

        trigger.addEventListener("click", function (e) {
          e.stopPropagation();
          var open = dropdown.classList.toggle("open");
          if (syncTrigger) trigger.classList.toggle("open", open);
        });

        document.addEventListener("click", function () {
          dropdown.classList.remove("open");
          if (syncTrigger) trigger.classList.remove("open");
        });

        dropdown.querySelectorAll("a").forEach(function (a) {
          a.addEventListener("click", function () {
            dropdown.classList.remove("open");
            if (syncTrigger) trigger.classList.remove("open");
          });
        });
      }

      setupDropdown("breadcrumb-toc-trigger", "breadcrumb-toc-dropdown", true);
      setupDropdown("mobile-toc-btn", "mobile-toc-dropdown", false);
    })();
  </script>

  <script is:inline>
    if (document.querySelector(".mermaid")) {
      var s = document.createElement("script");
      s.src = "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js";
      s.onload = function () {
        var theme = document.documentElement.getAttribute("data-theme") === "dark" ? "dark" : "default";
        var isDark = theme === "dark";
        mermaid.initialize({
          startOnLoad: true,
          theme: isDark ? "dark" : "default",
          themeVariables: isDark ? {
            primaryColor: "#2a2520",
            primaryBorderColor: "#4a4540",
            primaryTextColor: "#e6e4de",
            secondaryColor: "#1e1d1a",
            secondaryBorderColor: "#3a3530",
            tertiaryColor: "#252320",
            lineColor: "#6a6560",
            textColor: "#e6e4de",
            mainBkg: "#2a2520",
            nodeBorder: "#4a4540",
            clusterBkg: "#1e1d1a",
            clusterBorder: "#3a3530",
            titleColor: "#e6e4de",
            edgeLabelBackground: "#1b1a17",
          } : {
            primaryColor: "#fff3ec",
            primaryBorderColor: "#e6e4de",
            primaryTextColor: "#1d1b16",
            secondaryColor: "#f4f2ed",
            secondaryBorderColor: "#e6e4de",
            tertiaryColor: "#f8f6f1",
            lineColor: "#a09f9a",
            textColor: "#1d1b16",
            mainBkg: "#fff3ec",
            nodeBorder: "#e6e4de",
            clusterBkg: "#f4f2ed",
            clusterBorder: "#e6e4de",
            titleColor: "#1d1b16",
            edgeLabelBackground: "#faf9f6",
          },
        });
      };
      document.head.appendChild(s);
    }
  </script>

  <script is:inline>
    (function () {
      document.addEventListener("click", function (e) {
        var mermaidEl = e.target.closest(".markdown-body .mermaid");
        if (!mermaidEl) return;

        var svg = mermaidEl.querySelector("svg");
        if (!svg) return;

        var overlay = document.createElement("div");
        overlay.className = "mermaid-lightbox";

        var content = document.createElement("div");
        content.className = "mermaid-lightbox-content";

        // Clone SVG, resolve intrinsic size from viewBox first
        var cloned = svg.cloneNode(true);
        var vb = (svg.getAttribute("viewBox") || "").split(/[\s,]+/).map(Number);
        var origW, origH;
        if (vb.length === 4 && vb[2] > 0 && vb[3] > 0) {
          origW = vb[2];
          origH = vb[3];
        } else {
          origW = svg.getBoundingClientRect().width;
          origH = svg.getBoundingClientRect().height;
          cloned.setAttribute("viewBox", "0 0 " + origW + " " + origH);
        }
        cloned.removeAttribute("style");
        content.appendChild(cloned);

        var closeBtn = document.createElement("button");
        closeBtn.className = "mermaid-lightbox-close";
        closeBtn.setAttribute("aria-label", "Close");
        closeBtn.textContent = "\u00d7";

        var hint = document.createElement("div");
        hint.className = "mermaid-lightbox-hint";
        hint.textContent = "Scroll to zoom \u00b7 Drag to pan \u00b7 Esc to close";

        overlay.appendChild(content);
        overlay.appendChild(closeBtn);
        overlay.appendChild(hint);
        document.body.appendChild(overlay);
        document.body.style.overflow = "hidden";

        // Fit to 90% of viewport, no upper cap
        var scale = Math.min((window.innerWidth * 0.9) / origW, (window.innerHeight * 0.85) / origH);
        var tx = (window.innerWidth - origW * scale) / 2;
        var ty = (window.innerHeight - origH * scale) / 2;
        var dragging = false, didDrag = false;
        var startX = 0, startY = 0, startTx = 0, startTy = 0;

        // Resize SVG attributes directly so browser renders vector at target size
        function apply() {
          var w = origW * scale;
          var h = origH * scale;
          cloned.setAttribute("width", w);
          cloned.setAttribute("height", h);
          content.style.transform = "translate(" + tx + "px," + ty + "px)";
        }
        apply();

        function close() {
          document.body.removeChild(overlay);
          document.body.style.overflow = "";
        }

        closeBtn.addEventListener("click", close);
        overlay.addEventListener("click", function (ev) {
          if (didDrag) { didDrag = false; return; }
          if (ev.target === overlay) close();
        });

        document.addEventListener("keydown", function handler(ev) {
          if (ev.key === "Escape") {
            close();
            document.removeEventListener("keydown", handler);
          }
        });

        overlay.addEventListener("wheel", function (ev) {
          ev.preventDefault();
          var mx = ev.clientX;
          var my = ev.clientY;

          var prevScale = scale;
          var delta = ev.deltaY > 0 ? 0.9 : 1.1;
          scale = Math.max(scale * delta, 0.1);

          // Zoom toward mouse cursor
          tx = mx - (mx - tx) * (scale / prevScale);
          ty = my - (my - ty) * (scale / prevScale);
          apply();
        }, { passive: false });

        overlay.addEventListener("mousedown", function (ev) {
          if (ev.target === closeBtn) return;
          ev.preventDefault();
          dragging = true;
          didDrag = false;
          startX = ev.clientX;
          startY = ev.clientY;
          startTx = tx;
          startTy = ty;
        });

        window.addEventListener("mousemove", function (ev) {
          if (!dragging) return;
          var dx = ev.clientX - startX;
          var dy = ev.clientY - startY;
          if (Math.abs(dx) > 3 || Math.abs(dy) > 3) didDrag = true;
          tx = startTx + dx;
          ty = startTy + dy;
          apply();
        });

        window.addEventListener("mouseup", function () {
          dragging = false;
        });
      });
    })();
  </script>
</BaseLayout>
