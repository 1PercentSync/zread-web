---
import BaseLayout from "../layouts/BaseLayout.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import RepoCard from "../components/RepoCard.astro";
import { getRepos } from "../lib/content";

const repos = getRepos();
---

<BaseLayout title="zread">
  <header class="site-header">
    <div class="header-inner">
      <div class="header-left">
        <a href="/" class="header-logo">zread</a>
      </div>
      <div class="header-right">
        <ThemeToggle />
      </div>
    </div>
  </header>

  <main class="home-container">
    <h1 class="home-title">Repositories</h1>
    <p class="home-subtitle">Code documentation generated by zread</p>

    {repos.length > 0 ? (
      <div class="repo-grid">
        {repos.map((repo) => (
          <RepoCard repo={repo} />
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <h2>No repositories yet</h2>
        <p>Run the CLI in a project directory to sync documentation.</p>
      </div>
    )}
  </main>
</BaseLayout>
