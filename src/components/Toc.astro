---
interface Props {
  headings: { depth: number; text: string; id: string }[];
}

const { headings } = Astro.props;
---

{headings.length > 0 && (
  <aside class="toc">
    <div class="toc-title">On this page</div>
    <ul class="toc-list">
      {headings.map((h) => (
        <li>
          <a
            href={h.depth === 1 ? "#" : `#${h.id}`}
            class:list={["toc-link", `depth-${h.depth}`]}
            data-id={h.id}
          >
            {h.text}
          </a>
        </li>
      ))}
    </ul>
  </aside>
)}

<script is:inline>
  (function () {
    var toc = document.querySelector("aside.toc");
    if (!toc) return;
    var links = toc.querySelectorAll(".toc-link");
    if (!links.length) return;

    var headings = Array.from(
      document.querySelectorAll(".wiki-main h1[id], .wiki-main h2[id], .wiki-main h3[id]")
    );

    function update() {
      var active = null;
      if (window.scrollY > 0) {
        var scrollY = window.scrollY + 80;
        for (var i = headings.length - 1; i >= 0; i--) {
          if (headings[i].offsetTop <= scrollY) {
            active = headings[i];
            break;
          }
        }
      }
      links.forEach(function (l) { l.classList.remove("active"); });
      if (active) {
        var link = toc.querySelector('.toc-link[data-id="' + active.id + '"]');
        if (link) link.classList.add("active");
      } else {
        links[0].classList.add("active");
      }
    }

    window.addEventListener("scroll", update, { passive: true });
    update();
  })();
</script>
